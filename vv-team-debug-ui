// VV-MANAGER: Debug UI Injection
firebase.auth().onAuthStateChanged((user) => {
    const debugElement = document.createElement('div');
    debugElement.style.position = 'fixed';
    debugElement.style.top = '0';
    debugElement.style.left = '0';
    debugElement.style.width = '100%';
    debugElement.style.background = '#ff3b30';
    debugElement.style.color = '#fff';
    debugElement.style.padding = '20px';
    debugElement.style.zIndex = '9999';
    debugElement.style.textAlign = 'center';
    
    if (user) {
        debugElement.innerHTML = "UID DETECTAT: " + user.uid + "<br>(Copiază-l și trimite-mi-l)";
    } else {
        debugElement.innerHTML = "STATUS: Nelogat. Te rugăm să te autentifici.";
    }
    document.body.appendChild(debugElement);
});